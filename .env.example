# =========================
# QuantumGuard AI — Environment Variables
# =========================

# ── Supabase (shared) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Groq API (API Server only) ──
GROQ_API_KEY=gsk_your_groq_api_key

# ── GitHub (API Server only) ──
GITHUB_TOKEN=ghp_your_github_token

# ── API Server (Render) ──
PORT=3001
CORS_ORIGIN=https://your-frontend.vercel.app
SCANNER_ENGINE_URL=https://your-scanner-engine.onrender.com

# ── Scanner Engine (Render) ──
SCANNER_ENGINE_PORT=8000

# ── Frontend (Vercel) ──
VITE_API_URL=https://your-api-server.onrender.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
